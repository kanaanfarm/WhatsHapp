PORT=3000
NODE_ENV=production
SESSION_SECRET=replace-with-a-long-random-secret
PUBLIC_ORIGIN=https://connectchat-pro-kanaan.onrender.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-private-service-role-key
SUPABASE_BUCKET=connectchat-files
CALLS_ENABLED=false

# Required for reliable international calls. Obtain these from a TURN provider
# or from your own coturn server.
TURN_URL=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
TURN_USERNAME=replace-me
TURN_CREDENTIAL=replace-me

# ConnectChat AI (keep this key only on the server)
AI_DEMO_MODE=true
AI_ENABLED=false
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
# Optional custom behavior:
# AI_SYSTEM_PROMPT=You are ConnectChat AI...
